# AI Interview Evaluator — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env.

# Google Gemini API Key — get free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_actual_gemini_api_key_here

# Admin account password (default: admin123)
ADMIN_PASSWORD=admin123

# Set true for offline/demo mode — no API calls, scores generated locally (4-9 range)
USE_MOCK=false
